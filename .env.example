# ---- Copy this file to .env.local and fill in real values ----

# Shared password your bandmates type to unlock an invoice link.
BAND_PASSWORD="change-me-band"

# Secret used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="generate-a-long-random-string"

# Public base URL of the app (used to build share links and the Google OAuth
# redirect). No trailing slash.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ---- Google sign-in (the bookkeeping side) ----
# Create an OAuth 2.0 "Web application" client in Google Cloud Console and add
#   <base-url>/api/auth/google/callback
# as an authorized redirect URI (both your production domain and
# http://localhost:3000 for dev).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# The one Google account that manages the user allowlist. Always allowed in.
SUPER_ADMIN_EMAIL="you@gmail.com"

# ---- Your business info (prefills the admin form; all optional) ----
# Use \n inside BUSINESS_ADDRESS for line breaks.
BUSINESS_NAME="AKILA & The Wonder Machine"
BUSINESS_CONTACT="Akila Kavisinghe"
BUSINESS_ADDRESS="189 Beatrice Street\nToronto, Ontario, M6G 1R3"
BUSINESS_PHONE="647-760-7682"
BUSINESS_EMAIL="wondermachinemanagement@gmail.com"

# ---- Storage ----
# Leave BOTH blank for local dev → the app uses JSON files (./data/*.json).
# On Vercel (or any serverless host) set these to an Upstash Redis database.
# The Vercel Marketplace "Upstash" integration injects them automatically.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ---- Local library mode (only for `pnpm local` on your own computer) ----
# Runs the app as a local invoice organizer over a folder you control (put it
# inside Google Drive/Dropbox if you want your own cloud backup). Google
# sign-in is not used locally; the sync token authenticates you to the server.
# When running locally you can set BAND_PASSWORD/SESSION_SECRET to any dummy
# values — they aren't used in this mode.
#
# ALL of the values below are optional: the invoice folder, server URL and
# sync token can be set from the app UI instead (that's how the packaged
# desktop app works). Env values act as defaults until set in the app.
#LOCAL_MODE="1"
#REMOTE_SYNC_URL="https://your-app.vercel.app"
#REMOTE_SYNC_TOKEN="mis_...   (generate under Local sync on the /admin page)"
#INVOICE_DIR="/Users/you/Google Drive/Invoices"
