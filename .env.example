# ---- Copy this file to .env.local and fill in real values ----

# Shared password your bandmates type to unlock an invoice link.
BAND_PASSWORD="change-me-band"

# Admin password only YOU use to create invoice links (/admin).
ADMIN_PASSWORD="change-me-admin"

# Secret used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="generate-a-long-random-string"

# Public base URL of the app (used to build share links). No trailing slash.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
